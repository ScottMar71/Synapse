# Copy to .env locally; set the same keys in Vercel / GitHub Actions secrets (never commit real values).

NODE_ENV=development

# API (Hono) — required where the API runs (Vercel API project, local API dev).
API_BASE_URL=http://localhost:8787
TENANT_HEADER_NAME=x-tenant-id

# PostgreSQL — Supabase (EU): create the project in an EU region (e.g. Frankfurt / eu-central-1).
# Use the pooled connection for runtime (often port 6543, transaction mode).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
# Direct connection for Prisma migrations (port 5432). For local Postgres without a pooler, set equal to DATABASE_URL.
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
