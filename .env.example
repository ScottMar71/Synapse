# Copy to .env locally; set the same keys in Vercel / GitHub Actions secrets (never commit real values).

NODE_ENV=development

# Next.js web (`apps/web`) — origin of the deployed Hono API. Required at build time on Vercel because
# `next.config.mjs` rewrites `/api/v1/*` to this host. Use the public API base URL (no trailing path), e.g.:
#   https://your-api-project.vercel.app
LMS_API_ORIGIN=http://localhost:8787

# Optional — canonical browser URL for links (otherwise `VERCEL_URL` is used on Vercel).
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# API (Hono) — required where the API runs (Vercel API project, local API dev).
API_BASE_URL=http://localhost:8787
TENANT_HEADER_NAME=x-tenant-id

# PostgreSQL — Supabase (EU): create the project in an EU region (e.g. Frankfurt / eu-central-1).
# Use the pooled connection for runtime (often port 6543, transaction mode).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
# Direct connection for Prisma migrations (port 5432). For local Postgres without a pooler, set equal to DATABASE_URL.
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Lesson file attachments — S3-compatible object storage (Supabase Storage S3 API, AWS S3, or MinIO).
# When unset, local API uses noop presigned URLs (development only).
# Supabase: private bucket; Project Settings → Storage → S3 access keys; endpoint:
#   https://<project_ref>.supabase.co/storage/v1/s3
LMS_OBJECT_STORAGE_BUCKET=
LMS_OBJECT_STORAGE_REGION=eu-central-1
LMS_OBJECT_STORAGE_ACCESS_KEY=
LMS_OBJECT_STORAGE_SECRET_KEY=
LMS_OBJECT_STORAGE_ENDPOINT=
LMS_OBJECT_STORAGE_FORCE_PATH_STYLE=false
