{
  "name": "@conductor/database",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "node prisma/seed.mjs",
    "db:print-a11y-session": "node scripts/print-demo-session-exports.mjs",
    "db:reset": "prisma migrate reset --schema prisma/schema.prisma --force"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
